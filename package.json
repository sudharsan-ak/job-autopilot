{
  "name": "job-autopilot",
  "version": "1.0.0",
  "description": "Steps to follow: npm init -y npm i playwright dotenv npm i -D typescript ts-node @types/node npx playwright install",
  "main": "index.js",
  "scripts": {
    "authLinkedIn": "ts-node src/cli/authLinkedIn.ts",
    "authGreenhouse": "ts-node src/cli/authGreenhouse.ts",
    "authGmail": "ts-node src/cli/authGmail.ts",
    "collectLinkedIn": "ts-node src/cli/collectLinkedIn.ts",
    "analyzeJobs": "ts-node src/cli/analyzeJobs.ts",
    "enrichLinkedInCsvEmails": "ts-node src/cli/enrichLinkedInCsvEmails.ts",
    "createOutreachDrafts": "ts-node src/cli/automated/createOutreachDrafts.ts",
    "prepareManualOutreach": "ts-node src/cli/manual/prepareManualOutreach.ts",
    "draftEmails": "ts-node src/cli/manual/createManualOutreachDrafts.ts",
    "watchManualOutreach": "ts-node src/cli/manual/watchManualOutreach.ts",
    "recruiterOutreach": "ts-node src/cli/automated/recruiterOutreach.ts",
    "sendRecruiterOutreach": "ts-node src/cli/automated/sendRecruiterOutreach.ts",
    "applyBatchWindows": "ts-node src/cli/applyBatch_windows.ts",
    "applyBatchMac": "ts-node src/cli/applyBatch_mac.ts",
