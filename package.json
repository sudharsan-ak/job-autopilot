    "unknownJobsUI": "ts-node src/cli/unknownJobsUi.ts",
    "controllerUI": "ts-node src/cli/controllerUi.ts",
    "frontendJobs": "npm run collectLinkedIn -- --count=20 --url \"https://www.linkedin.com/jobs/search/?f_E=3%%2C4&f_F=it%%2Ceng&f_JT=F&f_T=9%%2C39%%2C25201%%2C3172%%2C1176&f_TPR=r86400&geoId=103644278&keywords=Frontend%%20Engineer%%20JavaScript%%20NOT%%20(%%22Easy%%20Apply%%22%%20OR%%20%%22Easy%%20Apply%%20only%%22%%20OR%%20%%22LinkedIn%%20Easy%%20Apply%%22%%20OR%%20%%226%%2B%%20years%%22%%20OR%%20%%227%%2B%%20years%%22%%20OR%%20%%228%%2B%%20years%%22%%20OR%%20%%2210%%2B%%20years%%22)&origin=JOB_SEARCH_PAGE_JOB_FILTER&refresh=true&sortBy=DD\"",
    "softwareJobs": "npm run collectLinkedIn -- --count=20 --url \"https://www.linkedin.com/jobs/search/?f_E=3%%2C4&f_F=it%%2Ceng&f_JT=F&f_T=9%%2C39%%2C25201%%2C3172%%2C1176&f_TPR=r86400&geoId=103644278&keywords=Software%%20Engineer%%20JavaScript%%20NOT%%20(%%22Easy%%20Apply%%22%%20OR%%20%%22Easy%%20Apply%%20only%%22%%20OR%%20%%22LinkedIn%%20Easy%%20Apply%%22%%20OR%%20%%226%%2B%%20years%%22%%20OR%%20%%227%%2B%%20years%%22%%20OR%%20%%228%%2B%%20years%%22%%20OR%%20%%2210%%2B%%20years%%22)&origin=JOB_SEARCH_PAGE_SEARCH_BUTTON&refresh=true&sortBy=DD\"",
    "fullstackJobs": "npm run collectLinkedIn -- --count=20 --url \"https://www.linkedin.com/jobs/search/?f_E=3%%2C4&f_F=it%%2Ceng&f_JT=F&f_T=9%%2C39%%2C25201%%2C3172%%2C1176&f_TPR=r86400&geoId=103644278&keywords=Full%%20Stack%%20Engineer%%20NOT%%20(%%22Easy%%20Apply%%22%%20OR%%20%%22Easy%%20Apply%%22%%20only%%22%%20OR%%20%%22LinkedIn%%20Easy%%20Apply%%22%%20OR%%20%%226%%2B%%20years%%22%%20OR%%20%%227%%2B%%20years%%22%%20OR%%20%%228%%2B%%20years%%22%%20OR%%20%%2210%%2B%%20years%%22)&origin=JOBS_HOME_KEYWORD_HISTORY\"",
    "start:sh": "npm run fullstackJobs && npm run frontendJobs && npm run softwareJobs"
  },
